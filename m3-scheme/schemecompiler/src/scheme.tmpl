/* Quake template for MScheme Level 1 Compiler integration.
   Usage in m3makefile:
     import("schemecompiler")
     scheme("foo")              -- compiles foo.scm, HIDDEN interface
     Scheme("foo")              -- compiles foo.scm, VISIBLE interface
     LinkCompiledScheme()       -- MUST call after all scheme() calls

   For cases where the .scm filename differs from the module name,
   use the internal helper directly:
     _scheme_compile("CompiledFoo", "foo.scm", HIDDEN)
     _scheme_compile("CompiledFoo", "foo.scm", VISIBLE)

   If the MScheme interpreter is not yet built (bootstrap), all
   scheme() calls silently become no-ops and the .scm files are
   loaded through the interpreter at runtime as usual. */

_SCHEME_MSCHEME  = PKG_INSTALL & SL & "mscheme-interactive" & SL & BUILD_DIR & SL & "mscheme"
_SCHEME_COMPILER = PKG_INSTALL & SL & "schemecompiler" & SL & "src" & SL & "compiler.scm"
_SCHEME_EXIT     = "exit"

_scheme_compiled_imports = ""

if fs_executable(_SCHEME_MSCHEME)
  _scheme_compiler_available = "TRUE"
else
  write("scheme.tmpl: MScheme compiler not found at " & _SCHEME_MSCHEME & "\n")
  write("scheme.tmpl: scheme() directives will be ignored; .scm files load via interpreter\n")
  _scheme_compiler_available = ""
end

readonly proc _scheme_compile(module_name, scm_file, visibility) is
  if not _scheme_compiler_available
    return
  end
  local src = path_of(scm_file)
  if stale(module_name & ".i3", src)
    local build_scm = module_name & "_scompile.scm"
    > build_scm in
      write("(load \"" & _SCHEME_COMPILER & "\")", CR)
      write("(compile-file \"" & src & "\" \"" & module_name & "\")", CR)
    end
    _exec([_SCHEME_MSCHEME, build_scm, _SCHEME_EXIT])
  end
  derived_interface(module_name, visibility)
  derived_implementation(module_name)
  if equal(_scheme_compiled_imports, "")
    _scheme_compiled_imports = module_name
  else
    _scheme_compiled_imports = _scheme_compiled_imports & ", " & module_name
  end
end

readonly proc _scheme_compile_path(module_name, abs_src_path, visibility) is
  if not _scheme_compiler_available
    return
  end
  if stale(module_name & ".i3", abs_src_path)
    local build_scm = module_name & "_scompile.scm"
    > build_scm in
      write("(load \"" & _SCHEME_COMPILER & "\")", CR)
      write("(compile-file \"" & abs_src_path & "\" \"" & module_name & "\")", CR)
    end
    _exec([_SCHEME_MSCHEME, build_scm, _SCHEME_EXIT])
  end
  derived_interface(module_name, visibility)
  derived_implementation(module_name)
  if equal(_scheme_compiled_imports, "")
    _scheme_compiled_imports = module_name
  else
    _scheme_compiled_imports = _scheme_compiled_imports & ", " & module_name
  end
end

readonly proc scheme(module_name) is
  local m3name = subst_chars(module_name, "-", "_")
  _scheme_compile(m3name, module_name & ".scm", HIDDEN)
end

readonly proc Scheme(module_name) is
  local m3name = subst_chars(module_name, "-", "_")
  _scheme_compile(m3name, module_name & ".scm", VISIBLE)
end

readonly proc LinkCompiledSchemeAs(unit_name) is
  if not equal(_scheme_compiled_imports, "")
    > unit_name & ".i3" in
      write("(* Generated by MScheme compiler template *)", CR)
      write("INTERFACE " & unit_name & ";", CR)
      write("END " & unit_name & ".", CR)
    end
    > unit_name & ".m3" in
      write("(* Generated by MScheme compiler template - forces module init *)", CR)
      write("MODULE " & unit_name & ";", CR)
      write("IMPORT " & _scheme_compiled_imports & ";", CR)
      write("BEGIN END " & unit_name & ".", CR)
    end
    derived_interface(unit_name, HIDDEN)
    derived_implementation(unit_name)
  end
end

readonly proc LinkCompiledScheme() is
  LinkCompiledSchemeAs("SchemeCompiled")
end
